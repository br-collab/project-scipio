          "detail": "Radar detection triggered defensive activation at the Matanzas node."
        },
        {
          "type": "add_risk",
          "value": 1
        }
      ]
    },
    {
      "id": "escalate_on_ring_entry",
      "condition": {
        "type": "uav_enters_ring",
        "red_id": "SAM-001",
        "unit_id": "UAV-ALPHA"
      },
      "effects": [
        {
          "type": "set_flag",
          "flag": "threat_escalated",
          "value": true
        },
        {
          "type": "add_event",
          "severity": "high",
          "summary": "Threat escalated",
          "detail": "UAV-ALPHA entered the Matanzas threat ring and the threat posture escalated."
        },
        {
          "type": "add_risk",
          "value": 2
        }
      ]
    },
    {
      "id": "humanitarian_penalty_on_roe_violation",
      "condition": {
        "type": "roe_violated"
      },
      "effects": [
        {
          "type": "set_flag",
          "flag": "humanitarian_penalty",
          "value": true
        },
        {
          "type": "add_event",
          "severity": "high",
          "summary": "Humanitarian penalty assessed",
          "detail": "ROE violation triggered a humanitarian penalty in the scenario logic."
        },
        {
          "type": "add_risk",
          "value": 2
        }
      ]
    }
